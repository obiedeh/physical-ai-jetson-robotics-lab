    # ══════════════════════════════════════════════════════════════════════
    # JOINTS
    # localPos0/Rot0 = URDF joint origin expressed in parent link frame
    # localPos1/Rot1 = identity (child link origin coincides with joint frame)
    # Revolute limits in DEGREES; prismatic limits in metres
    # ══════════════════════════════════════════════════════════════════════

    # ── Joint1: base_link → link1, Z-axis ────────────────────────────────
    def PhysicsRevoluteJoint "Joint1" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        uniform token physics:axis = "Z"
        rel physics:body0 = </Alicia_D_v5_6_gripper_50mm/base_link>
        rel physics:body1 = </Alicia_D_v5_6_gripper_50mm/link1>
        point3f physics:localPos0 = (0, 0, 0.1295)
        quatf physics:localRot0 = (1, 0, 0, 0)
        point3f physics:localPos1 = (0, 0, 0)
        quatf physics:localRot1 = (1, 0, 0, 0)
        float physics:lowerLimit = -157.45
        float physics:upperLimit = 157.45
        float drive:angular:physics:stiffness = 100.0
        float drive:angular:physics:damping = 10.0
        float drive:angular:physics:targetPosition = 0.0
        uniform token drive:angular:physics:type = "force"
    }

