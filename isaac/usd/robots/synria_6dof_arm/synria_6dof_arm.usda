"""
    kilogramsPerUnit = 1
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "synria_6dof_arm" (
    prepend references = @./payloads/base.usda@
    variants = {
        string Physics = "physx"
    }
    append variantSets = "Physics"
)
{
    variantSet "Physics" = {
        "mujoco" (
            prepend payload = @./payloads/Physics/mujoco.usda@
        ) {

        }
        "none" {

        }
        "physics" (
            prepend payload = @./payloads/Physics/physics.usda@
        ) {

        }
        "physx" (
            prepend payload = @./payloads/Physics/physx.usda@
        ) {

        }
    }
}

over "Flattened_Prototype_7"
{
    def Shader "PreviewSurface"
    {
        uniform token info:id = "UsdPreviewSurface"
        color3f inputs:diffuseColor.connect = </Flattened_Prototype_7.inputs:diffuseColor>
        float inputs:metallic.connect = </Flattened_Prototype_7.inputs:metallic>
        float inputs:opacity.connect = </Flattened_Prototype_7.inputs:opacity>
        float inputs:roughness.connect = </Flattened_Prototype_7.inputs:roughness>
        token outputs:displacement
        token outputs:surface
    }
}

